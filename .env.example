# Firebase client configuration for Daily Planner Phase 6A.
# Copy this file to `.env` (uncommitted) and fill in real values from the
# Firebase Console for the project you are targeting locally.
# Never commit real Firebase configuration values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Local emulator mode. Use a `demo-` prefixed project ID when this is "true".
# Emulator mode contacts only 127.0.0.1 and never live Firebase resources.
VITE_USE_FIREBASE_EMULATORS=false
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── General helpers ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isServerTs(field) {
      return request.resource.data[field] == request.time;
    }

    // ── Task helpers ──
    function hasExactTaskKeys() {
      return request.resource.data.keys().hasAll([
        'title', 'description', 'taskType', 'youtubeUrl', 'youtubeNotes',
        'lastWatchedSeconds', 'completed', 'completedAt', 'priority', 'category',
        'time', 'dueDate', 'createdAt', 'updatedAt'
      ]) && request.resource.data.keys().size() == 14;
    }

    function isValidTaskTypes() {
      let d = request.resource.data;
      return d.title is string && d.title.trim().size() > 0
          && d.description is string
          && d.taskType in ['standard', 'youtube']
          && d.youtubeUrl is string
          && d.youtubeNotes is string
          && d.lastWatchedSeconds is int && d.lastWatchedSeconds >= 0
          && d.completed is bool
          && ((d.completed == true && d.completedAt is timestamp) || (d.completed == false && d.completedAt == null))
          && d.priority in ['High', 'Medium', 'Low']
          && d.category in ['Work', 'Learning', 'Personal', 'Health']
          && (d.time == null || (d.time is string && d.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
          && (d.dueDate == null || (d.dueDate is string && d.dueDate.matches('^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$')))
          && d.createdAt is timestamp
          && d.updatedAt is timestamp;
    }

    function isValidTaskCreate() {
      let d = request.resource.data;
      return isServerTs('createdAt')
          && isServerTs('updatedAt')
          && d.completed == false
          && d.completedAt == null;
    }

    function isValidTaskUpdate() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isContentUpdate(diff)
          || isCompletionUpdate(diff)
          || isPlaybackOnlyUpdate(diff);
    }

    function isContentUpdate(diff) {
      let contentKeys = ['title', 'description', 'taskType', 'youtubeUrl',
                         'youtubeNotes', 'priority', 'category', 'time', 'dueDate'].toSet();
      let allowed = contentKeys.union(['updatedAt', 'lastWatchedSeconds'].toSet());

      return diff.hasAny(contentKeys)
          && diff.hasAll(['updatedAt'].toSet())
          && isServerTs('updatedAt')
          && !diff.hasAny(['createdAt', 'completed', 'completedAt'].toSet())
          && diff.difference(allowed).size() == 0
          && validContentPlayback(diff);
    }

    function validContentPlayback(diff) {
      let d = request.resource.data;
      return (diff.hasAll(['youtubeUrl'].toSet()) && d.lastWatchedSeconds == 0)
          || (!diff.hasAny(['youtubeUrl'].toSet()) && !diff.hasAny(['lastWatchedSeconds'].toSet()));
    }

    function isCompletionUpdate(diff) {
      let d = request.resource.data;
      let p = resource.data;

      return diff.hasOnly(['completed', 'completedAt', 'updatedAt'].toSet())
          && diff.size() == 3
          && isServerTs('updatedAt')
          && d.completed != p.completed
          && ((d.completed == true && d.completedAt == request.time)
           || (d.completed == false && d.completedAt == null));
    }

    function isPlaybackOnlyUpdate(diff) {
      return diff.hasOnly(['lastWatchedSeconds'].toSet())
          && diff.size() == 1;
    }

    // ── Idea helpers ──
    function hasExactIdeaKeys() {
      return request.resource.data.keys().hasAll([
        'text', 'notes', 'createdAt', 'updatedAt'
      ]) && request.resource.data.keys().size() == 4;
    }

    function isValidIdeaTypes() {
      let d = request.resource.data;
      return d.text is string && d.text.trim().size() > 0
          && d.notes is string
          && d.createdAt is timestamp
          && d.updatedAt is timestamp;
    }

    function isValidIdeaCreate() {
      return isServerTs('createdAt')
          && isServerTs('updatedAt');
    }

    function isValidIdeaUpdate() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let contentKeys = ['text', 'notes'].toSet();

      return diff.hasAny(contentKeys)
          && diff.hasAll(['updatedAt'].toSet())
          && isServerTs('updatedAt')
          && !diff.hasAny(['createdAt'].toSet())
          && diff.difference(contentKeys.union(['updatedAt'].toSet())).size() == 0;
    }

    // ── Deny parent user document ──
    match /users/{uid} {
      allow read, write: if false;
    }

    // ── Task rules ──
    match /users/{uid}/tasks/{taskId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasExactTaskKeys()
                       && isValidTaskTypes() && isValidTaskCreate();
      allow update: if isOwner(uid) && hasExactTaskKeys()
                       && isValidTaskTypes() && isValidTaskUpdate();
      allow delete: if isOwner(uid);
    }

    // ── Idea rules ──
    match /users/{uid}/ideas/{ideaId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasExactIdeaKeys()
                       && isValidIdeaTypes() && isValidIdeaCreate();
      allow update: if isOwner(uid) && hasExactIdeaKeys()
                       && isValidIdeaTypes() && isValidIdeaUpdate();
      allow delete: if isOwner(uid);
    }

    // ── Default deny (catch-all) ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}